# LLM vision on-premise (vide = mode demo deterministe hors-ligne)
# Pointer vers un serveur compatible OpenAI : vLLM ou Ollama.
EMPREINTE_LLM_API_BASE=
EMPREINTE_LLM_API_KEY=
EMPREINTE_LLM_MODEL_PRIMARY=Qwen/Qwen2.5-VL-7B-Instruct
EMPREINTE_LLM_MODEL_FALLBACK=llama3.2-vision
EMPREINTE_LLM_TIMEOUT_SEC=60
# Sortie JSON contrainte (guided decoding vLLM)
EMPREINTE_LLM_GUIDED_DECODING=true
# Disjoncteur du primaire
EMPREINTE_CIRCUIT_BREAKER_THRESHOLD=3
EMPREINTE_CIRCUIT_BREAKER_RESET_SEC=30
# Indicateurs sous ce seuil de confiance -> needs_review
EMPREINTE_EXTRACTION_MIN_CONFIDENCE=0.5

# Souverainete : true interdit tout endpoint LLM public (hors hote prive/local)
EMPREINTE_SOVEREIGN_MODE=true

# Ingestion
EMPREINTE_PDF_RENDER_DPI=150

# RAG reglementaire (vide = InMemoryRetriever de demo)
EMPREINTE_QDRANT_URL=
EMPREINTE_QDRANT_COLLECTION=empreinte_esrs

# Persistance (vide = etat en memoire de demo)
# Postgres async (psycopg) pour les metadonnees documents/rapports
EMPREINTE_SQL_DSN=
# Stockage objet S3-compatible (MinIO in-VPC) pour les images de pages
EMPREINTE_OBJECT_STORE_ENDPOINT=
EMPREINTE_OBJECT_STORE_BUCKET=empreinte
EMPREINTE_OBJECT_STORE_ACCESS_KEY=
EMPREINTE_OBJECT_STORE_SECRET_KEY=
EMPREINTE_OBJECT_STORE_REGION=us-east-1

# Reporting
EMPREINTE_REPORTING_YEAR=2025

# Securite — authentification : api_key (demo) ou jwt (prod OIDC)
EMPREINTE_AUTH_MODE=api_key
EMPREINTE_API_KEYS=dev-key-analyst:analyst,dev-key-auditor:auditor
# Mode jwt : RS256 via JWKS (prod) ou HS256 via secret
EMPREINTE_JWT_ALGORITHM=RS256
EMPREINTE_JWT_JWKS_URL=
EMPREINTE_JWT_SECRET=
EMPREINTE_JWT_ISSUER=
EMPREINTE_JWT_AUDIENCE=empreinte
EMPREINTE_JWT_ROLES_CLAIM=roles
EMPREINTE_JWT_TENANT_CLAIM=tenant_id
# Multi-tenant & RGPD
EMPREINTE_DEFAULT_TENANT=demo
EMPREINTE_RETENTION_DAYS=365
EMPREINTE_RATE_LIMIT_MAX_REQUESTS=60
EMPREINTE_RATE_LIMIT_WINDOW_SEC=60

# App
EMPREINTE_LOG_LEVEL=INFO
EMPREINTE_ENV=local
